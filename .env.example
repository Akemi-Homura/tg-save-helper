TG_API_ID=123456
TG_API_HASH=replace_with_your_api_hash
TG_SESSION_NAME=data/tg_save_helper
# Optional. If set, startup fails when it does not match the logged-in account.
OWNER_ID=
# Optional control bot created via @BotFather. Keep the token secret.
BOT_TOKEN=
# Optional. Defaults to the logged-in Telegram user ID.
BOT_OWNER_ID=
# Optional comma-separated resource bot whitelist.
TG_RESOURCE_BOTS=
MAX_RESOURCE_BOT_PAGES=100
MAX_RESOURCE_BOT_WAIT_SECONDS=120
MAX_RESOURCE_BOT_MESSAGES=2000
RESOURCE_BOT_START_INTERVAL_SECONDS=75
TG_FORWARD_INTERVAL_MIN_SECONDS=3
TG_FORWARD_INTERVAL_MAX_SECONDS=6
TG_FORWARD_BATCH_SIZE=50
TG_FORWARD_BATCH_PAUSE_MIN_SECONDS=30
TG_FORWARD_BATCH_PAUSE_MAX_SECONDS=60
# Optional paths/settings
TG_DATABASE_PATH=data/tg_save_helper.sqlite3
TG_SAVED_MEDIA_PATH=data/saved_media
LOG_LEVEL=INFO
TG_PANEL_ENABLED=0
TG_PANEL_HOST=127.0.0.1
TG_PANEL_PORT=8790
TG_PANEL_BASE_PATH=/tghelper
TG_PANEL_USERNAME=
TG_PANEL_PASSWORD=
